{
  "name": "execops-digital-systems-desktop",
  "version": "1.0.1",
  "private": true,
  "description": "Desktop app for Executive Operations Digital Systems (Partido State University)",
  "author": "Partido State University - Executive Operations",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:all": "bash scripts/build-installers.sh"
  },
  "build": {
    "appId": "ph.edu.parsu.execops.digitalsystems",
    "productName": "ExecOps Digital Systems",
    "copyright": "Copyright © Partido State University",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ],
      "artifactName": "ExecOps-Digital-Systems-Mac.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSMultipleInstancesProhibited": true
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ExecOps-Digital-Systems-Windows-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ExecOps Digital Systems",
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
